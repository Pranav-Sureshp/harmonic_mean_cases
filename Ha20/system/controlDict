application     cEpotFoam;  // mhdEpotMultiRegionFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         6;

deltaT          0.001;

writeControl    runTime;

writeInterval   2;

purgeWrite      3;

writeFormat     binary;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable yes;

maxCo           0.6;

maxDi           10.0;

adjustTimeStep  false;

